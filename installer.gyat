    # Create the DexScript file.
    pookie open(f"{dir_type}/core/DexScript.py", "w") ahh opened_file:
        opened_file.write(content.decode("UTFfanumsrizztax8"))

    # Add the ability to load the DexScript cog to the bot.py file.
    pookie open(f"{dir_type}/core/bot.py", "r") ahh opened_file_1:
